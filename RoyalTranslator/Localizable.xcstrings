            "value" : "Tutorial"
          }
        }
      }
    },
    "tutorial_show_now" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anleitung jetzt anzeigen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Show Tutorial"
          }
        }
      }
    },
    "tutorial_show_on_launch" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim Start anzeigen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Show on launch"
          }
        }
      }
    },
    "tutorial_step1_body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Übersetzer verwandelt deine modernen Worte in die Stimmen des mittelalterlichen Hofes. Die Bedeutung bleibt erhalten — nur die Stimme ändert sich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This translator transforms your modern words into the voices of the medieval court. The meaning stays the same — only the voice changes."
          }
        }
      }
    },
    "tutorial_step1_title" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Willkommen im Königlichen Übersetzer"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcome to the Royal Translator"
          }
        }
      }
    },
    "tutorial_step2_body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe auf die Stil-Chips, um einen oder mehrere mittelalterliche Charaktere auszuwählen. Aktive Chips sind hervorgehoben. Du kannst mehrere gleichzeitig verwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the style chips to select one or more medieval characters. Active chips are highlighted. You can use multiple voices at once."
          }
        }
      }
    },
    "tutorial_step2_title" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wähle deine Stimmen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose Your Voices"
          }
        }
      }
    },
    "tutorial_step3_body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwende die Filter-Chips, um Stile nach Sprache (Englisch / Deutsch), Geschlecht oder Rolle einzugrenzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use the filter chips to narrow styles by Language (English / German), Gender, or Role category (Royalty, Court, Folk…)."
          }
        }
      }
    },
    "tutorial_step3_title" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Reich filtern"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Filter the Realm"
          }
        }
      }
    },
    "tutorial_step4_body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe beliebigen modernen Text in das Eingabefeld. Der Übersetzer bewahrt die Bedeutung und kleidet sie in den Charakter der gewählten Figur."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Type any modern text into the input field. The translator preserves your meaning and dresses it in the chosen character's voice."
          }
        }
      }
    },
    "tutorial_step4_title" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gib deine Worte ein"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enter Your Words"
          }
        }
      }
    },
    "tutorial_step5_body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe auf den Übersetzen-Button. Jeder aktive Stil erzeugt seine eigene Version. Das Häkchen bestätigt, dass die Übersetzung gestartet wurde."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the Translate button. Each active style produces its own version. The checkmark confirms your translation was sent."
          }
        }
      }
    },
    "tutorial_step5_title" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übersetzen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Translate"
          }
        }
      }
    },
    "tutorial_step6_body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe auf den kursiven Originaltext oben auf einer Ergebniskarte, um ihn wieder in das Eingabefeld zu laden. Dann einfach anpassen und erneut übersetzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the italic original text at the top of any result card to reload it into the input field. Adjust and translate again."
          }
        }
      }
    },
    "tutorial_step6_title" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Originaltext antippen zum Bearbeiten"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap to Edit Again"
          }
        }
      }
    },
    "tutorial_step7_body" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe auf das Herz einer Karte, um sie zu speichern. Verwende den ♥-Filter, um nur gespeicherte Übersetzungen anzuzeigen. Favoriten bleiben auch nach dem Neustart erhalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the heart on any result card to save it. Use the ♥ filter to show only saved translations. Favourites persist across launches."
          }
        }
      }
    },
    "tutorial_step7_title" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Favoriten"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Favourites"
          }
        }
      }
    },
    "tutorial_title" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anleitung"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tutorial"
          }
        }
      }
    }
  },
  "version" : "1.1"
}