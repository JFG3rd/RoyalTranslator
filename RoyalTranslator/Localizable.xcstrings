    "coach_next" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Weiter" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Next" } }
      }
    },
    "coach_done" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Fertig" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Done" } }
      }
    },
    "coach_skip" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Überspringen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Skip" } }
      }
    },
    "coach_s1_title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Willkommen im Hof" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Welcome to the Court" } }
      }
    },
    "coach_s1_body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Der Royal Translator ist nun ein Gesprächssaal. Charaktere antworten als Sprechblasen. Eine kurze Führung — tippe auf Weiter." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Royal Translator is now a conversation chamber. Characters reply as chat bubbles. A quick tour — tap Next." } }
      }
    },
    "coach_s2_title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Unterhaltung" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The Conversation" } }
      }
    },
    "coach_s2_body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Charaktere antworten hier als Sprechblasen — jeder in seinem unverwechselbaren Stil. Neue Nachrichten erscheinen unten und scrollen automatisch hinein." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Characters reply here as chat bubbles — each in their distinctive style. New replies scroll in at the bottom." } }
      }
    },
    "coach_s3_title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Das Hofabzeichen" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The Court Badge" } }
      }
    },
    "coach_s3_body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zeigt an, wer gerade in deinem Hof ist. Tippe darauf, um Charaktere hinzuzufügen oder zu entlassen — mehrere gleichzeitig sind möglich." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Shows who is currently in your court. Tap to summon or dismiss characters — you can have several at once." } }
      }
    },
    "coach_s4_title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Deine Botschaft" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your Message" } }
      }
    },
    "coach_s4_body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Tippe hier alles ein — einen Gedanken, ein Zitat, eine Ansage. Die Charaktere werden es in ihrem unverwechselbaren Stil umformulieren." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Type anything here — a thought, a quote, an announcement. Characters will rephrase it in their own voice." } }
      }
    },
    "coach_s5_title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Senden" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Dispatch" } }
      }
    },
    "coach_s5_body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Tippe auf den Pfeil, um deine Botschaft an den Hof zu senden. Alle eingeladenen Charaktere antworten gleichzeitig." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Tap the arrow to dispatch your message. All summoned characters reply at once." } }
      }
    },
    "coach_s6_title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Antworten favorisieren" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Favouriting Replies" } }
      }
    },
    "coach_s6_body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Tippe auf das ♥ in einer Charakterblase, um genau diese Antwort zu speichern. Gespeicherte Antworten findest du im Tab Favoriten." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Tap ♥ inside any character's bubble to save that specific reply. Find saved replies in the Favourites tab." } }
      }
    },
    "coach_s7_title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Der Hof-Tab" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The Court Tab" } }
      }
    },
    "coach_s7_body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Hier wählst du alle verfügbaren Charaktere aus — gefiltert nach Sprache, Geschlecht und Rolle. Tippe auf eine Karte, um einen Charakter in deinen Hof zu laden oder zu entlassen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Browse all available characters here, filtered by language, gender, and role. Tap a card to summon or dismiss a character from your court." } }
      }
    },
    "coach_s8_title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Der Archiv-Tab" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The Archives Tab" } }
      }
    },
    "coach_s8_body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Alle bisherigen Sendungen werden hier nach Datum gespeichert. Tippe auf einen Eintrag, um die Antworten aufzuklappen. Wische nach links, um erneut zu senden — nach rechts, um zu löschen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Every past dispatch is saved here, grouped by date. Tap an entry to expand replies. Swipe left to re-dispatch, swipe right to delete." } }
      }
    },
    "coach_s9_title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Der Favoriten-Tab" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The Favourites Tab" } }
      }
    },
    "coach_s9_body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Jede einzelne Charakterantwort, die du mit ♥ markiert hast, wird hier gesammelt — nach Charakter oder nach Datum sortierbar. Wische links zum Kopieren, rechts zum Entfernen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Every character reply you've hearted appears here — sort by character or by date. Swipe left to copy, swipe right to remove." } }
      }
    },
    "coach_s10_title" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Der Reich-Tab" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The Realm Tab" } }
      }
    },
    "coach_s10_body" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Passe Schriftgröße, Standard-Charaktere und API-Schlüssel an. Diese Tour erscheint beim nächsten Start nicht mehr — du kannst sie jederzeit über die ? Schaltfläche erneut öffnen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Adjust font size, default characters, and your API key here. This tour won't auto-play again — tap ? anytime to reopen it." } }
      }
    },
