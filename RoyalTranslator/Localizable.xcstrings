  "strings" : {
    "" : {

    },
    "·" : {
      "comment" : "A period.",
      "isCommentAutoGenerated" : true
    },
    "\"%@\"" : {
      "comment" : "A label that shows the original text of a search result. The argument is the original text of the search result.",
      "isCommentAutoGenerated" : true
    },
    "%@ %@" : {
      "comment" : "A label with an emoji and a description of a translation style. The emoji is a small, stylized icon. The description is a short, one-word label for the translation style.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ %2$@"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A label at the bottom of the translator view showing the number of search results. The argument is the count of search results.",
      "isCommentAutoGenerated" : true
    },
    "%lld on" : {
      "comment" : "A badge showing the number of translations that are currently enabled. The argument is the number of enabled translations.",
      "isCommentAutoGenerated" : true
    },
    "+%lld" : {
      "comment" : "A number indicating the number of additional styles that are not shown in the row.",
      "isCommentAutoGenerated" : true
    },
    "♥" : {
      "comment" : "A heart emoji.",
      "isCommentAutoGenerated" : true
    },
    "⚜️" : {
      "comment" : "A title and subtitle for the API key screen.",
      "isCommentAutoGenerated" : true
    },
    "⚠️ %@" : {
      "comment" : "A warning message displayed when an error occurs during translation.",
      "isCommentAutoGenerated" : true
    },
    "🏰" : {
      "comment" : "A description of the emoji used as the title of the court.",
      "isCommentAutoGenerated" : true
    },
