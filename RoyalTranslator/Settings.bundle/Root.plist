<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>StringsTable</key>
    <string>Root</string>
    <key>PreferenceSpecifiers</key>
    <array>

        <!-- About -->
        <dict>
            <key>Type</key>            <string>PSGroupSpecifier</string>
            <key>Title</key>           <string>ABOUT_GROUP</string>
        </dict>
        <dict>
            <key>Type</key>            <string>PSTitleValueSpecifier</string>
            <key>Title</key>           <string>APP_VERSION_TITLE</string>
            <key>Key</key>             <string>app_version_display</string>
            <key>DefaultValue</key>    <string></string>
            <key>Values</key>          <array/>
            <key>Titles</key>          <array/>
        </dict>

        <!-- API Key -->
        <dict>
            <key>Type</key>            <string>PSGroupSpecifier</string>
            <key>Title</key>           <string>API_KEY_GROUP</string>
            <key>FooterText</key>      <string>API_KEY_FOOTER</string>
        </dict>
        <dict>
            <key>Type</key>            <string>PSToggleSwitchSpecifier</string>
            <key>Title</key>           <string>CLEAR_API_KEY_TITLE</string>
            <key>Key</key>             <string>clear_api_key</string>
            <key>DefaultValue</key>    <false/>
        </dict>

        <!-- Privacy -->
        <dict>
            <key>Type</key>            <string>PSGroupSpecifier</string>
            <key>Title</key>           <string>PRIVACY_GROUP</string>
            <key>FooterText</key>      <string>PRIVACY_FOOTER</string>
        </dict>

    </array>
</dict>
</plist>
